PORT=3000
NODE_ENV=production

# Acceso a la interfaz administrativa
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
SESSION_SECRET=generate-a-long-random-value

# Cifrado de credenciales Siigo en disco
CONFIG_ENCRYPTION_KEY=generate-another-long-random-value

# true permite recorrer la interfaz y probar la conexión sin llamar a Siigo
DEMO_MODE=false

# Opcional: ruta del archivo persistente
DATA_PATH=/app/data/state.json
